# Dockerfile para desarrollo con hot reload
FROM node:24-alpine

WORKDIR /app

# Copiar package.json primero para aprovechar caché de Docker
COPY package*.json ./

# Instalar dependencias
RUN npm install

# El código fuente se monta como volumen para hot reload
# No copiamos el código aquí

# Exponer puerto de Vite
EXPOSE 5173

# Comando para desarrollo con hot reload
CMD ["npm", "run", "dev", "--", "--host", "0.0.0.0"]

